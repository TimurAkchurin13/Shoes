<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaApplication1.ViewModels"
        x:Class="AvaloniaApplication1.Views.CreateOrderWindow"
        x:DataType="vm:CreateOrderWindowViewModel"
        Title="ООО &quot;Обувь&quot; - Оформление заказа"
        Width="700" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="White"
        Icon = "avares://AvaloniaApplication1/Assets/Icon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Оформление заказа"
                   FontFamily="Times New Roman"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="15">
                <!-- Пункт выдачи -->
                <StackPanel>
                    <TextBlock Text="Пункт выдачи:"
                               FontFamily="Times New Roman"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding PickupPoints}"
                              SelectedItem="{Binding SelectedPickupPoint}"
                              FontFamily="Times New Roman"
                              FontSize="14">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding PointCode}"/>
                                    <Run Text=" - "/>
                                    <Run Text="{Binding FullAddress}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <!-- Код выдачи (код пункта) под выбором -->
                    <TextBlock Text="{Binding SelectedPickupPoint.PointCode, StringFormat='Код пункта выдачи: {0}'}"
                               FontFamily="Times New Roman"
                               FontSize="12"
                               Foreground="Gray"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Дата доставки -->
                <StackPanel>
                    <TextBlock Text="Дата доставки:"
                               FontFamily="Times New Roman"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding DeliveryDate}"
                                FontFamily="Times New Roman"
                                FontSize="14"/>
                </StackPanel>

                <!-- Добавление товаров (если товар не был передан) -->
                <StackPanel IsVisible="{Binding HasAvailableProducts}">
                    <TextBlock Text="Добавить товар:"
                               FontFamily="Times New Roman"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,10,0,5"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailableProducts}"
                                  SelectedItem="{Binding SelectedProductToAdd}"
                                  FontFamily="Times New Roman"
                                  FontSize="14"
                                  Margin="0,0,10,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding Article}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding ProductName}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding PriceWithDiscount, StringFormat='{}{0:F0} ₽'}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1"
                                Content="Добавить товар"
                                Command="{Binding AddProductToCartCommand}"
                                Background="#00FA9A"
                                Foreground="Black"
                                FontFamily="Times New Roman"
                                FontSize="14"
                                Padding="15,8"
                                Cursor="Hand"/>
                    </Grid>
                </StackPanel>

                <!-- Корзина -->
                <TextBlock Text="Товары в заказе:"
                           FontFamily="Times New Roman"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,10,0,5"/>

                <ItemsControl ItemsSource="{Binding CartItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="10"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Product.ProductName}"
                                                   FontFamily="Times New Roman"
                                                   FontSize="14"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Product.Article}"
                                                   FontFamily="Times New Roman"
                                                   FontSize="12"
                                                   Foreground="#666666"/>
                                        <TextBlock FontFamily="Times New Roman"
                                                   FontSize="12"
                                                   Foreground="#666666">
                                            <Run Text="{Binding Product.PriceWithDiscount, StringFormat='{}{0:F0}'}"/>
                                            <Run Text=" ₽ за шт"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="10,0">
                                        <Button Content="-"
                                                Command="{Binding $parent[ItemsControl].((vm:CreateOrderWindowViewModel)DataContext).DecreaseQuantityCommand}"
                                                CommandParameter="{Binding}"
                                                Width="30"
                                                Height="30"
                                                FontSize="16"
                                                Background="#E0E0E0"
                                                Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Quantity}"
                                                   FontFamily="Times New Roman"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Width="30"
                                                   TextAlignment="Center"/>
                                        <Button Content="+"
                                                Command="{Binding $parent[ItemsControl].((vm:CreateOrderWindowViewModel)DataContext).IncreaseQuantityCommand}"
                                                CommandParameter="{Binding}"
                                                Width="30"
                                                Height="30"
                                                FontSize="16"
                                                Background="#E0E0E0"
                                                Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               FontFamily="Times New Roman"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="10,0">
                                        <Run Text="{Binding TotalPrice, StringFormat='{}{0:F0}'}"/>
                                        <Run Text=" ₽"/>
                                    </TextBlock>

                                    <Button Grid.Column="3"
                                            Content="✕"
                                            Command="{Binding $parent[ItemsControl].((vm:CreateOrderWindowViewModel)DataContext).RemoveItemCommand}"
                                            CommandParameter="{Binding}"
                                            Width="30"
                                            Height="30"
                                            FontSize="14"
                                            Background="#FF6B6B"
                                            Foreground="White"
                                            Margin="10,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Итого -->
        <Border Grid.Row="2"
                Background="#7FFF00"
                Padding="15"
                CornerRadius="5"
                Margin="0,20,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Итого:"
                           FontFamily="Times New Roman"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           FontFamily="Times New Roman"
                           FontSize="20"
                           FontWeight="Bold">
                    <Run Text="{Binding TotalAmount, StringFormat='{}{0:F0}'}"/>
                    <Run Text=" ₽"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">
            <Button Content="Отмена"
                    Command="{Binding CancelCommand}"
                    Background="#E0E0E0"
                    Foreground="Black"
                    FontFamily="Times New Roman"
                    FontSize="14"
                    Padding="20,10"
                    MinWidth="120"
                    Cursor="Hand"/>
            
            <Button Content="Оформить заказ"
                    Command="{Binding CreateOrderCommand}"
                    Background="#00FA9A"
                    Foreground="Black"
                    FontFamily="Times New Roman"
                    FontSize="14"
                    FontWeight="Bold"
                    Padding="20,10"
                    MinWidth="150"
                    IsEnabled="{Binding !IsLoading}"
                    Cursor="Hand"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   FontFamily="Times New Roman"
                   FontSize="12"
                   Foreground="Red"
                   VerticalAlignment="Center"
                   Margin="0,0,200,0"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </Grid>
</Window>

